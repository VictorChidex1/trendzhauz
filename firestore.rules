rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS — Enterprise-grade reusable security predicates
    // ══════════════════════════════════════════════════════════════════════

    // Returns true if the request comes from a logged-in user.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Fetches the requesting user's profile document and
    // returns their assigned role string ("super-admin" or "writer").
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Returns true if the logged-in user's role is "super-admin".
    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super-admin';
    }

    // Returns true if the logged-in user's role is "writer" OR "super-admin".
    function isWriter() {
      return isAuthenticated() && getUserRole() in ['writer', 'super-admin'];
    }

    // ──────────────────────────────────────────────────────────────────────
    // Author Ownership Check: ensures a writer can only mutate
    // their OWN posts. Super-admins bypass this check and can edit anyone's.
    // ──────────────────────────────────────────────────────────────────────
    function isOwnPost() {
      return resource.data.authorId == request.auth.uid;
    }

    // ──────────────────────────────────────────────────────────────────────
    // String length validators — prevents memory bomb / oversized
    // payload attacks. Hard caps derived from real editorial requirements.
    // ──────────────────────────────────────────────────────────────────────
    function isValidTitle () {
      return request.resource.data.title is string
          && request.resource.data.title.size() >= 3
          && request.resource.data.title.size() <= 300;
    }

    function isValidSlug() {
      return request.resource.data.slug is string
          && request.resource.data.slug.size() >= 3
          && request.resource.data.slug.size() <= 200;
    }

    function isValidDescription() {
      return request.resource.data.description is string
          && request.resource.data.description.size() >= 10
          && request.resource.data.description.size() <= 1000;
    }

    // ──────────────────────────────────────────────────────────────────────
    // searchIndex array size cap — prevents oversized array
    // injection. A well-tokenized title yields at most ~30 tokens; 50 is
    // a safe ceiling that still covers edge-case long headlines.
    // ──────────────────────────────────────────────────────────────────────
    function isValidSearchIndex() {
      return request.resource.data.searchIndex is list
          && request.resource.data.searchIndex.size() <= 50;
    }

    // ──────────────────────────────────────────────────────────────────────
    // Rating range guard — only triggered when the 'rating' field
    // is present (e.g. for review posts). Ensures value is 0.0 – 10.0.
    // ──────────────────────────────────────────────────────────────────────
    function isValidRating() {
      return !('rating' in request.resource.data)
          || (request.resource.data.rating is number
              && request.resource.data.rating >= 0.0
              && request.resource.data.rating <= 10.0);
    }

    // ──────────────────────────────────────────────────────────────────────
    // Exact field whitelist for CREATE — blocks data injection by
    // ensuring no unexpected fields can be written into a post document.
    // Required fields + all optional fields declared in post.ts are listed.
    // ──────────────────────────────────────────────────────────────────────
    function hasValidCreateFields() {
      let requiredFields = [
        'title', 'slug', 'description', 'content', 'category',
        'coverImageUrl', 'searchIndex', 'status', 'isEditorPick',
        'authorId', 'authorName', 'views', 'createdAt'
      ];
      let optionalFields = [
        'artistName', 'projectTitle', 'projectType', 'rating', 'verdict'
      ];
      let allAllowedFields = requiredFields.concat(optionalFields);
      return request.resource.data.keys().hasAll(requiredFields)
          && request.resource.data.keys().hasOnly(allAllowedFields);
    }

    // ──────────────────────────────────────────────────────────────────────
    // Exact field whitelist for UPDATE — all editable fields.
    // authorId and views remain immutable; createdAt MAY change so
    // super-admins / owning writers can reschedule or backdate posts.
    // ──────────────────────────────────────────────────────────────────────
    function hasValidUpdateFields() {
      let allowedFields = [
        'title', 'slug', 'description', 'content', 'category',
        'coverImageUrl', 'searchIndex', 'status', 'isEditorPick',
        'authorId', 'authorName', 'views', 'createdAt',
        'artistName', 'projectTitle', 'projectType', 'rating', 'verdict'
      ];
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    // Model A schedule gate: published posts only surface publicly once
    // createdAt is at or before the server clock (request.time).
    function isPubliclyVisible() {
      return resource.data.status == 'published'
          && resource.data.createdAt is timestamp
          && resource.data.createdAt <= request.time;
    }


    // ══════════════════════════════════════════════════════════════════════
    // 1. USERS COLLECTION — Role management profiles
    // ══════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Authenticated users can read profiles (e.g. to display author names).
      allow read: if isAuthenticated();

      // ONLY a super-admin can create, update, or delete user profile documents.
      // This is the primary guard against writers self-promoting their role to
      // 'super-admin'. Never relax this rule.
      allow write: if isSuperAdmin();
    }


    // ══════════════════════════════════════════════════════════════════════
    // 2. POSTS COLLECTION — Blog article documents
    // ══════════════════════════════════════════════════════════════════════
    match /posts/{postId} {

      // PUBLIC READ (Model A): published AND createdAt <= now.
      // Future-dated "scheduled" posts are hidden from the public.
      // Writers/super-admins can always read (CMS preview of scheduled/drafts).
      allow read: if isWriter() || isPubliclyVisible();

      // ── CREATE ──────────────────────────────────────────────────────────
      // createdAt may be past (backdate), now, or future (schedule).
      // Category enum: "Music" | "Videos" | "Reviews" | "News"
      allow create: if isWriter()
        && hasValidCreateFields()
        && isValidTitle()
        && isValidSlug()
        && isValidDescription()
        && isValidSearchIndex()
        && isValidRating()
        && request.resource.data.content is string
        && request.resource.data.content.size() >= 1
        && request.resource.data.category in ['Music', 'Videos', 'Reviews', 'News']
        && request.resource.data.coverImageUrl is string
        && request.resource.data.status in ['draft', 'published']
        && request.resource.data.isEditorPick is bool
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.views == 0
        && request.resource.data.createdAt is timestamp;

      // ── UPDATE ──────────────────────────────────────────────────────────
      // Writers: own posts only. Super-admins: any post.
      // authorId and views are immutable.
      // createdAt MAY change for reschedule / backdate (Model A).
      allow update: if hasValidUpdateFields()
        && isValidTitle()
        && isValidSlug()
        && isValidDescription()
        && isValidSearchIndex()
        && isValidRating()
        && request.resource.data.category in ['Music', 'Videos', 'Reviews', 'News']
        && request.resource.data.status in ['draft', 'published']
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.views == resource.data.views
        && request.resource.data.createdAt is timestamp
        && (isSuperAdmin() || (isWriter() && isOwnPost()));

      // ── DELETE ──────────────────────────────────────────────────────────
      // Only a super-admin can permanently remove a post.
      allow delete: if isSuperAdmin();
    }


    // ══════════════════════════════════════════════════════════════════════
    // 3. LINKTREE COLLECTION — Bio link items
    // ══════════════════════════════════════════════════════════════════════
    match /linktree/{linkId} {
      // PUBLIC READ: Anyone can read bio links (the /links page is public).
      allow read: if true;

      // ── ANONYMOUS CLICK TRACKING ─────────────────────────────────────────
      // Public visitors can increment clickCount by exactly 1.
      // ALL other fields must remain byte-for-byte identical to prevent
      // anonymous users from corrupting link data.
      // The request.auth == null guard explicitly enforces that this path
      // is only taken by unauthenticated (anonymous) users.
      allow update: if request.auth == null
        && request.resource.data.clickCount == resource.data.clickCount + 1
        && request.resource.data.title == resource.data.title
        && request.resource.data.targetUrl == resource.data.targetUrl
        && request.resource.data.iconType == resource.data.iconType
        && request.resource.data.order == resource.data.order
        && request.resource.data.isActive == resource.data.isActive;

      // ── ADMIN FULL UPDATE ────────────────────────────────────────────────
      // Super-admins can update any field (reorder, rename, toggle, change URL).
      allow update: if isSuperAdmin();

      // CREATE & DELETE: Only a super-admin can add or remove bio links.
      allow create, delete: if isSuperAdmin();
    }


    // ══════════════════════════════════════════════════════════════════════
    // 4. AGGREGATIONS COLLECTION — Pre-computed homepage feeds
    // ══════════════════════════════════════════════════════════════════════
    // Written exclusively by the server-side Cloud Function via Admin SDK,
    // which bypasses these rules entirely. No client-side writes are allowed.
    match /aggregations/{docId} {
      allow read: if true;
      allow write: if false;
    }


    // ══════════════════════════════════════════════════════════════════════
    // 5. DEFAULT DENY — Deny-all fallback for any unmatched collection.
    // ══════════════════════════════════════════════════════════════════════
    // This is the last line of defence: any collection that is NOT explicitly
    // matched above (e.g. a typo-named collection, or future dev experiments)
    // will have ALL reads and writes blocked by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
